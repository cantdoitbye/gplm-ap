# ========================================
# AIKOSH-5 Environment Configuration
# ========================================
# Copy this file to .env and fill in your values

# ========================================
# Database Configuration
# ========================================
DATABASE_URL=postgresql://aikosh5:aikosh5_password@localhost:5432/aikosh5
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ========================================
# Redis Configuration
# ========================================
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ========================================
# MinIO / Object Storage Configuration
# ========================================
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_IMAGERY=satellite-imagery
MINIO_BUCKET_GIS=gis-data
MINIO_BUCKET_MODELS=ml-models

# ========================================
# Copernicus Data Space (Sentinel-2)
# ========================================
# Register at: https://dataspace.copernicus.eu/
COPERNICUS_USERNAME=your_username_here
COPERNICUS_PASSWORD=your_password_here
COPERNICUS_API_URL=https://catalogue.dataspace.copernicus.eu/odata/v1

# ========================================
# Google Earth Engine
# ========================================
# Register at: https://earthengine.google.com/
GOOGLE_EARTH_ENGINE_KEY=

# ========================================
# Mapbox (Map Tiles)
# ========================================
# Get free token at: https://www.mapbox.com/
MAPBOX_ACCESS_TOKEN=your_mapbox_token_here
MAPBOX_STYLE_MAP=mapbox://styles/mapbox/streets-v12
MAPBOX_STYLE_SATELLITE=mapbox://styles/mapbox/satellite-streets-v12

# ========================================
# OpenStreetMap / Overpass API
# ========================================
OVERPASS_API_URL=https://overpass-api.de/api/interpreter

# ========================================
# Google Open Buildings
# ========================================
GOOGLE_OPEN_BUILDINGS_URL=https://sites.research.google/gr/open-buildings

# ========================================
# AI/ML Configuration
# ========================================
# Model settings
MODEL_DEVICE=cpu
MODEL_CONFIDENCE_THRESHOLD=0.5
YOLO_MODEL_PATH=models/yolov8_building.pt

# Federated Learning
FL_SERVER_HOST=localhost
FL_SERVER_PORT=8080
FL_MIN_CLIENTS=3
FL_ROUNDS=10

# ========================================
# API Configuration
# ========================================
API_HOST=0.0.0.0
API_PORT=8000
API_DEBUG=true
API_RELOAD=true
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ========================================
# JWT Authentication
# ========================================
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ========================================
# Trust Score Configuration
# ========================================
TRUST_SCORE_DECAY_DAYS=30
TRUST_SCORE_MIN_THRESHOLD=0.3

# ========================================
# Celery Configuration
# ========================================
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ========================================
# Logging Configuration
# ========================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ========================================
# Optional: OpenAI API (for enhanced reasoning)
# ========================================
OPENAI_API_KEY=

# ========================================
# Optional: Sentinel Hub (alternative to Copernicus)
# ========================================
SENTINELHUB_CLIENT_ID=
SENTINELHUB_CLIENT_SECRET=

# ========================================
# Area of Interest (Andhra Pradesh Sample)
# ========================================
AOI_CENTER_LAT=16.5062
AOI_CENTER_LON=80.6480
AOI_BUFFER_KM=10

# ========================================
# Mock Data Settings
# ========================================
MOCK_DATA_SEED=42
MOCK_PROPERTIES_COUNT=1000
MOCK_MUNICIPALITIES_COUNT=3
